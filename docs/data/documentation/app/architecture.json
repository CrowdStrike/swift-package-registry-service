{"primaryContentSections":[{"content":[{"anchor":"Architecture-Diagram","text":"Architecture Diagram","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Visually, the architecture can be described as:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"HighLevelArchitecture"}],"type":"paragraph"},{"inlineContent":[{"text":"Each of the components above are the following:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Checksum Client. This can be found in the ","type":"text"},{"code":"ChecksumClient","type":"codeVoice"},{"text":" module, and is an abstraction of a SHA256 checksum.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"GithubAPIClient. This is an abstraction of the minimal set of Github API endpoints that we need. The public"},{"type":"text","text":" "},{"type":"text","text":"API can be found in the "},{"type":"codeVoice","code":"GithubAPIClient"},{"type":"text","text":" module, and the implementation can be found in the "},{"type":"codeVoice","code":"GithubAPIClientImpl"},{"type":"text","text":" module."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Github OpenAPI Codegen. This can be found in the ","type":"text"},{"code":"GithubOpenAPI","type":"codeVoice"},{"text":" module. It uses the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/apple\/swift-openapi-generator","type":"reference"},{"text":" ","type":"text"},{"text":"Swift Package Manager plugin to generate code from the Github API.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"HTTP Stream Client. This can be found in the ","type":"text"},{"code":"HTTPStreamClient","type":"codeVoice"},{"text":" module, and is an abstraction of an HTTP client.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Persistence Client. This is a client for reading and writing cached data to\/from the disk. It can","type":"text"},{"text":" ","type":"text"},{"text":"be found in the ","type":"text"},{"type":"codeVoice","code":"PersistenceClient"},{"text":" module.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"File Client. This is an abstraction for a file system, and can be found in the "},{"type":"codeVoice","code":"FileClient"},{"type":"text","text":" module."}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"For all of our clients, we use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies"},{"text":" style of clients.","type":"text"}],"type":"paragraph"},{"anchor":"Swift-Package-Registry-Service-endpoints","text":"Swift Package Registry Service endpoints","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"As described "},{"identifier":"https:\/\/github.com\/swiftlang\/swift-package-manager\/blob\/main\/Documentation\/PackageRegistry\/Registry.md#4-endpoints","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"a Swift Package Registry Service must implement 6 endpoints:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"List Package Releases ("},{"type":"codeVoice","code":"GET \/{scope}\/{name}"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"text":"Fetch Release Metadata (","type":"text"},{"code":"GET \/{scope}\/{name}\/{version}","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fetch Manifest ("},{"type":"codeVoice","code":"GET \/{scope}\/{name}\/{version}\/Package.swift"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Download Source Archive ("},{"code":"GET \/{scope}\/{name}\/{version}.zip","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Lookup Package Identifiers ("},{"type":"codeVoice","code":"GET \/identifiers?url="},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"text":"Create Package Release (","type":"text"},{"type":"codeVoice","code":"PUT \/{scope}\/{name}\/{version}"},{"text":")","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"text":"However, the Create Package Release endpoint is optional. From the spec:","type":"text"}],"type":"paragraph"},{"code":["Support for this endpoint is OPTIONAL. A server SHOULD indicate that publishing isn't supported by responding with a status code of 405 (Method Not Allowed)."],"type":"codeListing","syntax":null},{"inlineContent":[{"type":"text","text":"Since we are only interested in our service being a read-only service, then we do not support publishing, and thus the Create Package Release"},{"type":"text","text":" "},{"type":"text","text":"endpoint always returns "},{"type":"codeVoice","code":"405 Method Not Allowed"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The sections which follow provide more detail into the implementation of each of the endpoints."}],"type":"paragraph"},{"anchor":"List-Package-Releases-implementation","text":"List Package Releases implementation","type":"heading","level":2},{"inlineContent":[{"text":"The List Packages Releases (","type":"text"},{"code":"GET \/{scope}\/{name}","type":"codeVoice"},{"text":") endpoint is implemented as follows:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Do checks to validate the input parameters (package scope, package name, and Accept header)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the memory cache for tag information for this package:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"If there is cached tag information and it is less than 5 minutes old, then use it to construct the response.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Otherwise, we proceed to step 3 to refresh the memory-cached tag information."}],"type":"paragraph"}]}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Attempt to read the cached tag information from the disk cache. If the age"},{"type":"text","text":" "},{"type":"text","text":"of the disk-cached tag information is less than 30 minutes old, then use to to construct"},{"type":"text","text":" "},{"type":"text","text":"the response. Otherwise, proceed to step 4 to refresh the disk-cached tag information."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If we have at least one tag in the disk-cache, then call the Github API"},{"type":"text","text":" "},{"identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/repos?apiVersion=2022-11-28#list-repository-tags","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"endpoint to fetch the latest tag. If the latest tag was present in the disk cache,"},{"type":"text","text":" "},{"type":"text","text":"then we know the disk cache is up-to-date and we use the tag information"},{"type":"text","text":" "},{"type":"text","text":"in the disk cache to construct the response. Otherwise, we proceed to step 5."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Next, using the same"},{"type":"text","text":" "},{"overridingTitle":"List Repository Tags","type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"List Repository Tags"}],"identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/repos?apiVersion=2022-11-28#list-repository-tags"},{"type":"text","text":" "},{"type":"text","text":"endpoint, we fetch all of the tags for this repository, one page at a time."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Next we compute the mapping from semantic version to tags."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Next we write out the list of tags and the version-to-tag mapping to disk cache."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Then we return the list of semantic versions in the response."}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Fetch-Release-Metadata-Implementation","text":"Fetch Release Metadata Implementation","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"There is currently no API in the Github API to return the SHA256 checksum"},{"type":"text","text":" "},{"type":"text","text":"of a source archive. Some developers have written Github Actions like "},{"identifier":"https:\/\/github.com\/marketplace\/actions\/sha256-checksum","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"or "},{"identifier":"https:\/\/github.com\/jmgilman\/actions-generate-checksum","type":"reference","isActive":true},{"type":"text","text":". So therefore,"},{"type":"text","text":" "},{"type":"text","text":"since the source archive checksum is part of the Release Metadata information,"},{"type":"text","text":" "},{"type":"text","text":"then we have to download the source archive and computes its checksum before"},{"type":"text","text":" "},{"type":"text","text":"responding."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The Fetch Release Metadata ("},{"type":"codeVoice","code":"GET \/{scope}\/{name}\/{version}"},{"type":"text","text":") endpoint is implemented as follows:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do checks to validate the input parameters (package scope, package name, package version,"},{"type":"text","text":" "},{"type":"text","text":"and Accept header)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the memory cache for release metadata for this package. If it is present,"},{"type":"text","text":" "},{"type":"text","text":"then use it to construct the response. Otherwise, go to step 3."}]}]},{"content":[{"inlineContent":[{"text":"Check the disk cache for release metadata for this package. If it is present,","type":"text"},{"text":" ","type":"text"},{"text":"then use it to constrct the response. Otherwise, go to step 4.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Do steps 2-8 from the List Package Releases to fetch the tag information for this respository."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Find the tag which corresponds to the input semantic version."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Call the "},{"identifier":"https:\/\/docs.github.com\/en\/rest\/releases\/releases?apiVersion=2022-11-28#get-a-release-by-tag-name","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"Github API endpoint to find the "},{"code":"publishedAt","type":"codeVoice"},{"type":"text","text":" date for this tag. It is not an error"},{"type":"text","text":" "},{"type":"text","text":"if no release is associated with that tag. In that case, we simply don’t provide"},{"type":"text","text":" "},{"type":"text","text":"a "},{"code":"publishedAt","type":"codeVoice"},{"type":"text","text":" "},{"code":"Date","type":"codeVoice"},{"type":"text","text":" in the response."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Next we download the source archive for this tag to disk.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Next we compute the SHA256 checksum for this source archive.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Next we save the version and its associated tag, the SHA256 checksum, and the "},{"type":"codeVoice","code":"publishedAt"},{"type":"text","text":" date"},{"type":"text","text":" "},{"type":"text","text":"to the disk cache."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Then we return this same information and construct the response.","type":"text"}]}]}],"type":"orderedList"},{"anchor":"Fetch-Manifest-Implementation","text":"Fetch Manifest Implementation","type":"heading","level":2},{"inlineContent":[{"text":"The Fetch Manifest (","type":"text"},{"code":"GET \/{scope}\/{name}\/{version}\/Package?swift-version=","type":"codeVoice"},{"text":") endpoint","type":"text"},{"text":" ","type":"text"},{"text":"is implemented as follows:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do checks to validate the input parameters (package scope, package name, package version,"},{"type":"text","text":" "},{"type":"text","text":"and Accept Header)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Check the memory cache for manifest information for this package version. If it is present,","type":"text"},{"text":" ","type":"text"},{"text":"then skip to step 11 to return the response.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the disk cache for manifest information for this package version. If it is present,"},{"type":"text","text":" "},{"type":"text","text":"then skip to step 11 to return the response."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Do steps 2-8 from the List Package Releases to fetch the tag information for this respository."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Look up the tag for the input semantic version.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Use the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/contents?apiVersion=2022-11-28#get-repository-content","type":"reference"},{"text":" ","type":"text"},{"text":"Github API endpoint to fetch the directory contents of the root of the repository.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Look through the filenames of the files in the respository root to find all of","type":"text"},{"text":" ","type":"text"},{"text":"the package manifests. If we don’t find any, then return a 404 Not Found.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use the same","type":"text"},{"text":" ","type":"text"},{"overridingTitleInlineContent":[{"type":"text","text":"Get Repository Content"}],"type":"reference","overridingTitle":"Get Repository Content","identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/contents?apiVersion=2022-11-28#get-repository-content","isActive":true},{"text":" ","type":"text"},{"text":"Github API endpoint to fetch each of the package manifests found in step 7.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"For each of the manifests, parse out the "},{"type":"codeVoice","code":"swift-tools-version"},{"type":"text","text":" found at the top"},{"type":"text","text":" "},{"type":"text","text":"of each manifest."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Save each of the manifests to disk cache, and save the list of manifests (along with"},{"type":"text","text":" "},{"type":"text","text":"their "},{"type":"codeVoice","code":"swift-tools-version"},{"type":"text","text":") to disk."}]}]},{"content":[{"inlineContent":[{"text":"If had a ","type":"text"},{"type":"codeVoice","code":"swift-version"},{"text":" query parameter in the request, then find the","type":"text"},{"text":" ","type":"text"},{"text":"corresponding package manifest in the manifest information, and return that","type":"text"},{"text":" ","type":"text"},{"text":"manifest. If there was no swift-version-specific package manifest corresponding","type":"text"},{"text":" ","type":"text"},{"text":"to the specified ","type":"text"},{"type":"codeVoice","code":"swift-version"},{"text":", then return a 303 See Other response,","type":"text"},{"text":" ","type":"text"},{"text":"with the Location header pointing to the un-versioned package manifest.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If we did not have a "},{"code":"swift-version","type":"codeVoice"},{"type":"text","text":" query parameter in the request,"},{"type":"text","text":" "},{"type":"text","text":"then look up the un-versioned package manifest in the manifest information,"},{"type":"text","text":" "},{"type":"text","text":"and return it. Include any information about the other swift-version-specific"},{"type":"text","text":" "},{"type":"text","text":"manifests in the Link header."}]}]}],"type":"orderedList"},{"anchor":"Download-Source-Archive-Implementation","text":"Download Source Archive Implementation","type":"heading","level":2},{"inlineContent":[{"text":"The Download Source Archive (","type":"text"},{"type":"codeVoice","code":"GET \/{scope}\/{name}\/{version}.zip"},{"text":") endpoint is implemented","type":"text"},{"text":" ","type":"text"},{"text":"as follows:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Do checks to validate the input parameters (package scope, package name, package version,"},{"type":"text","text":" "},{"type":"text","text":"Accept header)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Do steps 2-10 in the Fetch Release Metadata implementation to fetch","type":"text"},{"text":" ","type":"text"},{"text":"release metadata. This will also result in the source archive for the specified","type":"text"},{"text":" ","type":"text"},{"text":"version being downloaded.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Read the source archive from disk and return it in the response."}]}]}],"type":"orderedList"},{"anchor":"Lookup-Package-Identifiers-Implementation","text":"Lookup Package Identifiers Implementation","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The Lookup Package Identifiers ("},{"code":"GET \/identifiers?url=","type":"codeVoice"},{"type":"text","text":") endpoint is implemented"},{"type":"text","text":" "},{"type":"text","text":"as follows:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do checks to validate the input parameters ("},{"type":"codeVoice","code":"url"},{"type":"text","text":" query parameter and Accept header)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parse the input "},{"type":"codeVoice","code":"url"},{"type":"text","text":" query parameter. It must be in one of the following three forms."},{"type":"text","text":" "},{"type":"text","text":"If it is not, then return a 404 Not Found."}]},{"items":[{"content":[{"inlineContent":[{"text":"An “HTML URL” of the form ","type":"text"},{"type":"codeVoice","code":"https:\/\/github.com\/<scope>\/<name>"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A “Clone URL” of the form "},{"type":"codeVoice","code":"https:\/\/github.com\/<scope>\/<name>.git"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An “SSH URL” of the form ","type":"text"},{"type":"codeVoice","code":"git@github.com:<scope>\/<name>.git"}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Check the memory cache for a package ID for this URL. If it is present,","type":"text"},{"text":" ","type":"text"},{"text":"then return it in the response. Otherwise, go to step 4.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Check the database for a cached Repository which has a clone URL, HTML URL, or SSH URL","type":"text"},{"text":" ","type":"text"},{"text":"equal to the input URL. If we find it, then return the package ID of this repository.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise, go to step 5.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Call the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/repos?apiVersion=2022-11-28#get-a-repository"},{"type":"text","text":" "},{"type":"text","text":"Github API endpoint to fetch information for this repository. If this API call"},{"type":"text","text":" "},{"type":"text","text":"returns 404 Not Found, then we also return 404 Not Found. Otherwise, go to step 6."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Save the Repository information returned by the Github API to the database.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Return the package ID of the Repository returned by the Gitub API.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"modules":[{"name":"App"}],"role":"article","roleHeading":"Article","title":"Architecture"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/app\/architecture"]}],"seeAlsoSections":[{"anchor":"Essentials","generated":true,"identifiers":["doc:\/\/App\/documentation\/App\/GettingStarted","doc:\/\/App\/documentation\/App\/GithubAPI","doc:\/\/App\/documentation\/App\/ToDoList"],"title":"Essentials"}],"kind":"article","hierarchy":{"paths":[["doc:\/\/App\/documentation\/App"]]},"identifier":{"url":"doc:\/\/App\/documentation\/App\/Architecture","interfaceLanguage":"swift"},"abstract":[{"text":"This article describes the architecture of the Swift Package Registry Service.","type":"text"}],"references":{"https://github.com/swiftlang/swift-package-manager/blob/main/Documentation/PackageRegistry/Registry.md#4-endpoints":{"url":"ht