y of use only when tracing the execution of a program.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Debug"}],"type":"strong"},{"text":": Messages that contain information normally of use only when debugging a program.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Info"}],"type":"strong"},{"text":": Informational messages.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Notice"}]},{"text":": Conditions that are not error conditions, but that may require special handling.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Warning"}],"type":"strong"},{"type":"text","text":": Messages that are not error conditions, but more severe than Notice."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Error"}],"type":"strong"},{"text":": Error conditions.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Critical"}]},{"text":": Critical error conditions that usually require immediate attention.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The default Vapor logging level is Info. If you want to change the logging level, see the"},{"type":"text","text":" "},{"type":"text","text":"instructions below."}],"type":"paragraph"},{"level":3,"text":"Using Xcode","type":"heading","anchor":"Using-Xcode"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click the "},{"type":"codeVoice","code":"swift-package-registry-service"},{"type":"text","text":" scheme."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click Edit Scheme.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click the Run action in the left pane.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Click the Arguments tab in the top middle.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a "},{"code":"--log <log-level>","type":"codeVoice"},{"type":"text","text":" argument, where "},{"code":"<log-level>","type":"codeVoice"},{"type":"text","text":" is "},{"code":"trace","type":"codeVoice"},{"type":"text","text":", "},{"code":"debug","type":"codeVoice"},{"type":"text","text":", "},{"code":"info","type":"codeVoice"},{"type":"text","text":", "},{"code":"notice","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"warning","type":"codeVoice"},{"type":"text","text":", "},{"code":"error","type":"codeVoice"},{"type":"text","text":", or "},{"code":"critical","type":"codeVoice"},{"type":"text","text":"."}]}]}],"type":"orderedList"},{"level":3,"text":"Using swift command line","type":"heading","anchor":"Using-swift-command-line"},{"inlineContent":[{"type":"text","text":"Add a "},{"code":"--log <log-level>","type":"codeVoice"},{"type":"text","text":" to your "},{"code":"swift run","type":"codeVoice"},{"type":"text","text":" command, where "},{"code":"<log-level>","type":"codeVoice"},{"type":"text","text":" is "},{"code":"trace","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"debug","type":"codeVoice"},{"type":"text","text":", "},{"code":"info","type":"codeVoice"},{"type":"text","text":", "},{"code":"notice","type":"codeVoice"},{"type":"text","text":", "},{"code":"warning","type":"codeVoice"},{"type":"text","text":", "},{"code":"error","type":"codeVoice"},{"type":"text","text":", or "},{"code":"critical","type":"codeVoice"},{"type":"text","text":". For example, to set "},{"code":"debug","type":"codeVoice"},{"type":"text","text":"-level logging:"}],"type":"paragraph"},{"syntax":null,"code":["swift run --log debug"],"type":"codeListing"}],"kind":"content"