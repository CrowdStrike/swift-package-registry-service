{"identifier":{"url":"doc:\/\/App\/documentation\/App\/Architecture","interfaceLanguage":"swift"},"kind":"article","metadata":{"role":"article","roleHeading":"Article","title":"Architecture","modules":[{"name":"App"}]},"sections":[],"hierarchy":{"paths":[["doc:\/\/App\/documentation\/App"]]},"abstract":[{"text":"This article describes the architecture of the Swift Package Registry Service.","type":"text"}],"seeAlsoSections":[{"title":"Essentials","generated":true,"identifiers":["doc:\/\/App\/documentation\/App\/GettingStarted","doc:\/\/App\/documentation\/App\/ConfiguringSPM","doc:\/\/App\/documentation\/App\/GithubAPI","doc:\/\/App\/documentation\/App\/SpecificationSupport","doc:\/\/App\/documentation\/App\/ToDoList"],"anchor":"Essentials"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Architecture Diagram","anchor":"Architecture-Diagram","type":"heading","level":2},{"inlineContent":[{"text":"Visually, the architecture can be described as:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"HighLevelArchitecture"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Each of the components above are the following:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Checksum Client. This can be found in the "},{"code":"ChecksumClient","type":"codeVoice"},{"type":"text","text":" module, and is an abstraction of a SHA256 checksum."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"GithubAPIClient. This is an abstraction of the minimal set of Github API endpoints that we need. The public"},{"text":" ","type":"text"},{"type":"text","text":"API can be found in the "},{"code":"GithubAPIClient","type":"codeVoice"},{"type":"text","text":" module, and the implementation can be found in the "},{"type":"codeVoice","code":"GithubAPIClientImpl"},{"text":" module.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Github OpenAPI Codegen. This can be found in the ","type":"text"},{"code":"GithubOpenAPI","type":"codeVoice"},{"type":"text","text":" module. It uses the "},{"identifier":"https:\/\/github.com\/apple\/swift-openapi-generator","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"Swift Package Manager plugin to generate code from the Github API."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"HTTP Stream Client. This can be found in the ","type":"text"},{"type":"codeVoice","code":"HTTPStreamClient"},{"text":" module, and is an abstraction of an HTTP client.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Persistence Client. This is a client for reading and writing cached data to\/from the disk. It can"},{"type":"text","text":" "},{"text":"be found in the ","type":"text"},{"type":"codeVoice","code":"PersistenceClient"},{"type":"text","text":" module."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"File Client. This is an abstraction for a file system, and can be found in the "},{"type":"codeVoice","code":"FileClient"},{"type":"text","text":" module."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For all of our clients, we use the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies"},{"type":"text","text":" style of clients."}]},{"text":"Swift Package Registry Service endpoints","level":2,"anchor":"Swift-Package-Registry-Service-endpoints","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As described "},{"identifier":"https:\/\/github.com\/swiftlang\/swift-package-manager\/blob\/main\/Documentation\/PackageRegistry\/Registry.md#4-endpoints","isActive":true,"type":"reference"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a Swift Package Registry Service must implement 6 endpoints:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"List Package Releases ("},{"type":"codeVoice","code":"GET \/{scope}\/{name}"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"text":"Fetch Release Metadata (","type":"text"},{"type":"codeVoice","code":"GET \/{scope}\/{name}\/{version}"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fetch Manifest ("},{"type":"codeVoice","code":"GET \/{scope}\/{name}\/{version}\/Package.swift"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Download Source Archive (","type":"text"},{"code":"GET \/{scope}\/{name}\/{version}.zip","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Lookup Package Identifiers (","type":"text"},{"code":"GET \/identifiers?url=","type":"codeVoice"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Create Package Release (","type":"text"},{"type":"codeVoice","code":"PUT \/{scope}\/{name}\/{version}"},{"type":"text","text":")"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"However, the Create Package Release endpoint is optional. From the spec:","type":"text"}]},{"syntax":null,"type":"codeListing","code":["Support for this endpoint is OPTIONAL. A server SHOULD indicate that publishing isn't supported by responding with a status code of 405 (Method Not Allowed)."]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since we are only interested in our service being a read-only service, then we do not support publishing, and thus the Create Package Release"},{"type":"text","text":" "},{"type":"text","text":"endpoint always returns "},{"type":"codeVoice","code":"405 Method Not Allowed"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The sections which follow provide more detail into the implementation of each of the endpoints."}]},{"text":"List Package Releases implementation","level":2,"type":"heading","anchor":"List-Package-Releases-implementation"},{"inlineContent":[{"text":"The List Packages Releases (","type":"text"},{"type":"codeVoice","code":"GET \/{scope}\/{name}"},{"type":"text","text":") endpoint is implemented as follows:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Do checks to validate the input parameters (package scope, package name, and Accept header)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the memory cache for tag information for this package:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is cached tag information and it is less than 5 minutes old, then use it to construct the response."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Otherwise, we proceed to step 3 to refresh the memory-cached tag information."}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Attempt to read the cached tag information from the disk cache. If the age"},{"type":"text","text":" "},{"text":"of the disk-cached tag information is less than 30 minutes old, then use to to construct","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the response. Otherwise, proceed to step 4 to refresh the disk-cached tag information."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"If we have at least one tag in the disk-cache, then call the Github API"},{"type":"text","text":" "},{"identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/repos?apiVersion=2022-11-28#list-repository-tags","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"endpoint to fetch the latest tag. If the latest tag was present in the disk cache,"},{"text":" ","type":"text"},{"text":"then we know the disk cache is up-to-date and we use the tag information","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the disk cache to construct the response. Otherwise, we proceed to step 5."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Next, using the same","type":"text"},{"text":" ","type":"text"},{"type":"reference","overridingTitleInlineContent":[{"text":"List Repository Tags","type":"text"}],"overridingTitle":"List Repository Tags","identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/repos?apiVersion=2022-11-28#list-repository-tags","isActive":true},{"type":"text","text":" "},{"type":"text","text":"endpoint, we fetch all of the tags for this repository, one page at a time."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Next we compute the mapping from semantic version to tags.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Next we write out the list of tags and the version-to-tag mapping to disk cache.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Then we return the list of semantic versions in the response."}],"type":"paragraph"}]}]},{"type":"heading","text":"Fetch Release Metadata Implementation","level":2,"anchor":"Fetch-Release-Metadata-Implementation"},{"inlineContent":[{"text":"There is currently no API in the Github API to return the SHA256 checksum","type":"text"},{"text":" ","type":"text"},{"text":"of a source archive. Some developers have written Github Actions like ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/marketplace\/actions\/sha256-checksum","isActive":true},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"reference","identifier":"https:\/\/github.com\/jmgilman\/actions-generate-checksum","isActive":true},{"type":"text","text":". So therefore,"},{"type":"text","text":" "},{"type":"text","text":"since the source archive checksum is part of the Release Metadata information,"},{"type":"text","text":" "},{"type":"text","text":"then we have to download the source archive and computes its checksum before"},{"type":"text","text":" "},{"type":"text","text":"responding."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The Fetch Release Metadata (","type":"text"},{"code":"GET \/{scope}\/{name}\/{version}","type":"codeVoice"},{"type":"text","text":") endpoint is implemented as follows:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Do checks to validate the input parameters (package scope, package name, package version,"},{"type":"text","text":" "},{"type":"text","text":"and Accept header)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the memory cache for release metadata for this package. If it is present,"},{"type":"text","text":" "},{"type":"text","text":"then use it to construct the response. Otherwise, go to step 3."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the disk cache for release metadata for this package. If it is present,"},{"type":"text","text":" "},{"type":"text","text":"then use it to constrct the response. Otherwise, go to step 4."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Do steps 2-8 from the List Package Releases to fetch the tag information for this respository."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Find the tag which corresponds to the input semantic version.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Call the "},{"identifier":"https:\/\/docs.github.com\/en\/rest\/releases\/releases?apiVersion=2022-11-28#get-a-release-by-tag-name","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"Github API endpoint to find the ","type":"text"},{"code":"publishedAt","type":"codeVoice"},{"type":"text","text":" date for this tag. It is not an error"},{"type":"text","text":" "},{"text":"if no release is associated with that tag. In that case, we simply don’t provide","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a "},{"code":"publishedAt","type":"codeVoice"},{"type":"text","text":" "},{"type":"codeVoice","code":"Date"},{"type":"text","text":" in the response."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Next we download the source archive for this tag to disk."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Next we compute the SHA256 checksum for this source archive.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Next we save the version and its associated tag, the SHA256 checksum, and the ","type":"text"},{"type":"codeVoice","code":"publishedAt"},{"text":" date","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the disk cache."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Then we return this same information and construct the response."}]}]}],"type":"orderedList"},{"level":2,"type":"heading","anchor":"Fetch-Manifest-Implementation","text":"Fetch Manifest Implementation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Fetch Manifest ("},{"type":"codeVoice","code":"GET \/{scope}\/{name}\/{version}\/Package?swift-version="},{"type":"text","text":") endpoint"},{"text":" ","type":"text"},{"type":"text","text":"is implemented as follows:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do checks to validate the input parameters (package scope, package name, package version,"},{"text":" ","type":"text"},{"type":"text","text":"and Accept Header)."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Check the memory cache for manifest information for this package version. If it is present,"},{"text":" ","type":"text"},{"text":"then skip to step 11 to return the response.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Check the disk cache for manifest information for this package version. If it is present,"},{"text":" ","type":"text"},{"text":"then skip to step 11 to return the response.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do steps 2-8 from the List Package Releases to fetch the tag information for this respository."}]}]},{"content":[{"inlineContent":[{"text":"Look up the tag for the input semantic version.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the"},{"type":"text","text":" "},{"identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/contents?apiVersion=2022-11-28#get-repository-content","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"Github API endpoint to fetch the directory contents of the root of the repository."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Look through the filenames of the files in the respository root to find all of","type":"text"},{"text":" ","type":"text"},{"text":"the package manifests. If we don’t find any, then return a 404 Not Found.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Use the same","type":"text"},{"type":"text","text":" "},{"overridingTitle":"Get Repository Content","isActive":true,"identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/contents?apiVersion=2022-11-28#get-repository-content","type":"reference","overridingTitleInlineContent":[{"text":"Get Repository Content","type":"text"}]},{"text":" ","type":"text"},{"text":"Github API endpoint to fetch each of the package manifests found in step 7.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For each of the manifests, parse out the ","type":"text"},{"code":"swift-tools-version","type":"codeVoice"},{"text":" found at the top","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of each manifest."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Save each of the manifests to disk cache, and save the list of manifests (along with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"their "},{"code":"swift-tools-version","type":"codeVoice"},{"text":") to disk.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"If had a ","type":"text"},{"type":"codeVoice","code":"swift-version"},{"type":"text","text":" query parameter in the request, then find the"},{"type":"text","text":" "},{"text":"corresponding package manifest in the manifest information, and return that","type":"text"},{"text":" ","type":"text"},{"text":"manifest. If there was no swift-version-specific package manifest corresponding","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the specified "},{"type":"codeVoice","code":"swift-version"},{"text":", then return a 303 See Other response,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with the Location header pointing to the un-versioned package manifest."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If we did not have a "},{"code":"swift-version","type":"codeVoice"},{"text":" query parameter in the request,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then look up the un-versioned package manifest in the manifest information,"},{"type":"text","text":" "},{"text":"and return it. Include any information about the other swift-version-specific","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"manifests in the Link header."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Download-Source-Archive-Implementation","level":2,"text":"Download Source Archive Implementation"},{"inlineContent":[{"type":"text","text":"The Download Source Archive ("},{"code":"GET \/{scope}\/{name}\/{version}.zip","type":"codeVoice"},{"type":"text","text":") endpoint is implemented"},{"type":"text","text":" "},{"type":"text","text":"as follows:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Do checks to validate the input parameters (package scope, package name, package version,"},{"type":"text","text":" "},{"type":"text","text":"Accept header)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Do steps 2-10 in the Fetch Release Metadata implementation to fetch"},{"type":"text","text":" "},{"text":"release metadata. This will also result in the source archive for the specified","type":"text"},{"type":"text","text":" "},{"text":"version being downloaded.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Read the source archive from disk and return it in the response."}]}]}]},{"text":"Lookup Package Identifiers Implementation","anchor":"Lookup-Package-Identifiers-Implementation","level":2,"type":"heading"},{"inlineContent":[{"text":"The Lookup Package Identifiers (","type":"text"},{"type":"codeVoice","code":"GET \/identifiers?url="},{"text":") endpoint is implemented","type":"text"},{"type":"text","text":" "},{"text":"as follows:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Do checks to validate the input parameters (","type":"text"},{"type":"codeVoice","code":"url"},{"text":" query parameter and Accept header)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Parse the input ","type":"text"},{"code":"url","type":"codeVoice"},{"text":" query parameter. It must be in one of the following three forms.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If it is not, then return a 404 Not Found."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"An “HTML URL” of the form "},{"code":"https:\/\/github.com\/<scope>\/<name>","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A “Clone URL” of the form "},{"type":"codeVoice","code":"https:\/\/github.com\/<scope>\/<name>.git"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An “SSH URL” of the form ","type":"text"},{"type":"codeVoice","code":"git@github.com:<scope>\/<name>.git"}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Check the memory cache for a package ID for this URL. If it is present,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then return it in the response. Otherwise, go to step 4."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the database for a cached Repository which has a clone URL, HTML URL, or SSH URL"},{"text":" ","type":"text"},{"type":"text","text":"equal to the input URL. If we find it, then return the package ID of this repository."},{"type":"text","text":" "},{"text":"Otherwise, go to step 5.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Call the"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/repos?apiVersion=2022-11-28#get-a-repository","type":"reference"},{"type":"text","text":" "},{"text":"Github API endpoint to fetch information for this repository. If this API call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returns 404 Not Found, then we also return 404 Not Found. Otherwise, go to step 6."}]}]},{"content":[{"inlineContent":[{"text":"Save the Repository information returned by the Github API to the database.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Return the package ID of the Repository returned by the Gitub API.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/app\/architecture"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"HighLevelArchitectur