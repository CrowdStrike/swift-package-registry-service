pendencies","type":"link","titleInlineContent":[{"text":"swift-dependencies","type":"text"}]},"https://github.com/jmgilman/actions-generate-checksum":{"type":"link","title":"this","url":"https:\/\/github.com\/jmgilman\/actions-generate-checksum","titleInlineContent":[{"type":"text","text":"this"}],"identifier":"https:\/\/github.com\/jmgilman\/actions-generate-checksum"},"doc://App/documentation/App/GettingStarted":{"kind":"article","identifier":"doc:\/\/App\/documentation\/App\/GettingStarted","abstract":[{"type":"text","text":"Learn how to build and run the Swift Package Registry Service."}],"type":"topic","title":"Getting started","role":"article","url":"\/documentation\/app\/gettingstarted"},"doc://App/documentation/App/ConfiguringSPM":{"kind":"article","abstract":[{"type":"text","text":"Learn how to configure your Swift Package Manager to use the package registry."}],"url":"\/documentation\/app\/configuringspm","title":"Configuring Swift Package Manager","identifier":"doc:\/\/App\/documentation\/App\/ConfiguringSPM","role":"article","type":"topic"},"https://docs.github.com/en/rest/repos/repos?apiVersion=2022-11-28#get-a-repository":{"url":"https:\/\/docs.github.com\/en\/rest\/repos\/repos?apiVersion=2022-11-28#get-a-repository","identifier":"https:\/\/docs.github.com\/en\/rest\/repos\/repos?apiVersion=2022-11-28#get-a-repository","type":"link","titleInlineContent":[{"text":"Get Repository","type":"text"}],"title":"Get Repository"},"doc://App/documentation/App/GithubAPI":{"kind":"article","abstract":[{"text":"We can implement a Swift Package Registry Service by using these four operations in the Github API:","type":"text"}],"url":"\/documentation\/app\/githubapi","title":"Github API","identifier":"doc:\/\/App\/documentation\/App\/GithubAPI","role":"article","type":"topic"},"doc://App/documentation/App":{"type":"topic","abstract":[{"type":"text","text":"The Swift Package Registry Service is a Vapor-based web service which implements the Swift Package Registry Service Specification by proxying and caching the Github API."}],"identifier":"doc:\/\/App\/documentation\/App","kind":"symbol","title":"App","role":"collection","url":"\/documentation\/app"},"doc://App/documentation/App/SpecificationSupport":{"title":"Specification Support","role":"article","type":"topic","abstract":[{"text":"See the status of each feature in the Swift Package Registry Service specification.","type":"text"}],"url":"\/documentation\/app\/specificationsupport","identifier":"doc:\/\/App\/documentation\/App\/SpecificationSupport","kind":"article"},"https://docs.github.com/en/rest/releases/releases?apiVersion=2022-11-28#get-a-release-by-tag-name":{"type":"link","title":"Get A Release By Tag Name","url":"https:\/\/docs.github.com\/en\/rest\/releases\/releases?apiVersion=2022-11-28#get-a-release-by-tag-name","titleInlineContent":[{"type":"text","text":"Get A Release By Tag Name"}],"identifier":"https:\/\/docs.github.com\/en\/rest\/releases\/releases?apiVersion=2022-11-28#get-a-release-by-tag-name"},"https://github.com/apple/swift-openapi-generator":{"url":"https:\/\/github.com\/apple\/swift-openapi-generator","identifier":"https:\/\/github.com\/apple\/swift-openapi-generator","type":"link","titleInlineContent":[{"text":"swift-openapi-generator","type":"text"}],"title":"swift-openapi-generator"},"https://github.com/marketplace/actions/sha256-checksum":{"type":"link","title":"this","url":"https:\/\/github.com\/marketplace\/actions\/sha256-checksum","titleInlineContent":[{"type":"text","text":"this"}],"identifier":"https:\/\/github.com\/marketplace\/actions\/sha256-checksum"}}}